# Environment Variables for Production Deployment on Render

# MongoDB Atlas Connection String (REQUIRED for Render)
# Get this from MongoDB Atlas: Clusters > Connect > Connect your application
MONGO_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/your-database?retryWrites=true&w=majority&appName=your-app-name

# JWT Secret for authentication (generate a new secure one for production)
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random

# GNews API Key for news fetching
GNEWS_API_KEY=your-gnews-api-key-here

# Frontend URL for CORS (your Vercel app URL)
FRONTEND_URL=https://your-frontend-app.vercel.app

# Port (automatically set by Render - don't change this)
PORT=10000