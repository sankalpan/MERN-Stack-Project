# Environment Variables for Production Deployment

# MongoDB Connection String
MONGO_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/your-database?retryWrites=true&w=majority

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-here

# GNews API Key for news fetching
GNEWS_API_KEY=your-gnews-api-key-here

# Frontend URL for CORS (your Vercel app URL)
FRONTEND_URL=https://your-frontend-app.vercel.app

# Port (automatically set by Render)
PORT=10000